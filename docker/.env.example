# Application Settings
APP_NAME='Smart Attendance System'
APP_VERSION=0.1.0
DEBUG=False
ENVIRONMENT=production

# Database Settings (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=attendu_db
DB_SCHEMA=public
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/attendu_db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Security
SECRET_KEY=your_secret_key_here_minimum_32_chars_required
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend URL
FRONTEND_URL=http://localhost:5001

# PgAdmin Settings (optional)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
